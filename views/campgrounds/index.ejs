<% layout('layouts/boilerplate')%>
<div id="cluster-map"></div>
<h1 class="mt-2">All Campgrounds</h1>
<div>
  <a class="btn btn-primary mb-2" href="/campgrounds/new">Add Campground</a>
</div>
<ul class="list-unstyled ps-0">
  <% for (let campground of campgrounds){ %>
  <li class="list-unstyled card mb-3">
    <div class="row g-0">
      <div class="col-12 col-md-4">
        <% if(campground.images.length){ %>
        <img crossorigin="anonymous" src="<%= campground.images[0].url %>" alt="<%= campground.title %> image" loading="lazy" class="w-100 h-100 object-fit-cover img-fluid">
        <% } else{ %>
        <img crossorigin="anonymous" src="https://res.cloudinary.com/dpfmu5i9p/image/upload/v1757175214/YelpCamp/sfyipzhlpyhmvrnlwz2f.jpg" alt="<%= campground.title %> image" class="w-100 h-100 object-fit-cover img-fluid">
        <% } %>
      </div>
      <div class="col-12 col-md-8">
        <div class="card-body">
          <h5 class="card-title"> <%= campground.title %></h5>
          <p class="card-text card-desc-clamp"><%= campground.description %></p>
          <p class="card-text">
            <small class="text-body-secondary"><%= campground.location %></small>
          </p>
          <a href="/campgrounds/<%= campground._id %>" class="btn btn-primary">View Campground</a>
        </div>
      </div>
    </div>
  </li>
  <% } %>
</ul>

<script>
  const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
  const campgrounds = {
    features: <%- JSON.stringify(campgrounds) %>
  }
</script>
<script src="/javascripts/clusterMap.js"></script>